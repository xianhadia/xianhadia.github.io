---
layout: null
---
[{% assign entries = "" | split: "" %}{% for page in site.pages %}{% if page.title and page.url != '/404.html' %}{% capture entry %}{
  "title": {{ page.title | jsonify }},
  "url": {{ page.url | prepend: site.baseurl | jsonify }},
  "content": {{ page.content | strip_html | truncatewords: 200 | jsonify }}
}{% endcapture %}{% assign entries = entries | push: entry %}{% endif %}{% endfor %}{% for entry in entries %}{{ entry }}{% unless forloop.last %},{% endunless %}{% endfor %}]
